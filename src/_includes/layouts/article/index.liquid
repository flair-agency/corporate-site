---
layout: layouts/base/index.liquid
tags: article
---
<main
  data-variant="article"
  data-slug="news-{{ page.fileSlug }}"
  style="view-transition-name: news-{{ page.fileSlug }}"
>
  <style>
    :root {
      --asset-hero: image-set(
        url('/news/hero.avif?v={{ site.asset.version }}') type('image/avif'),
        url('/news/hero.webp?v={{ site.asset.version }}') type('image/webp'),
        url('/news/hero.webp?v={{ site.asset.version }}') type('image/jpg'),
        url('/news/hero.png?v={{ site.asset.version }}') type('image/png')
      );
    }
  </style>

  <section id="top" class="hero">
    <hgroup>
      <h2>{{ hero.title | default: title }}</h2>
      <p>{{ hero.subtitle | default: '' }}</p>
    </hgroup>
  </section>

  <section>
    <article>
      {{ content }}
      <footer>
        <ul class="hashtags" aria-label="ハッシュタグ">
          {% for tag in hashtags %}
            <li>
              <span class="hashtag fas fa-hashtag">{{ tag }}</span>
            </li>
          {% endfor %}
        </ul>
        <time
          class="fas fa-calendar"
          datetime="{{ date | default: page.date | date: "%Y-%m-%dT%H:%M:%S" }}"
        >
          {{ date | default: page.date | date: '%Y年%m月%d日' }}
        </time>
      </footer>
    </article>
  </section>
</main>
